# Supabase — obter em: https://supabase.com/dashboard/project/<project>/settings/api
VITE_SUPABASE_URL=https://<project>.supabase.co
VITE_SUPABASE_ANON_KEY=<anon-key>

# WhatsApp Embedded Signup (Meta) — configurar ANTES de habilitar o módulo WhatsApp
# 1. Crie um App no Meta for Developers (tipo Business) com product "WhatsApp"
# 2. Ative "Embedded Signup" e crie uma configuração em App > WhatsApp > Embedded Signup
# 3. O App ID é público (ok expor via VITE_). O App Secret vai APENAS no Supabase Secrets.
# Ver docs: https://developers.facebook.com/docs/whatsapp/embedded-signup
VITE_META_APP_ID=<meta-app-id>
VITE_META_EMBEDDED_SIGNUP_CONFIG_ID=<embedded-signup-config-id>
# Supabase Secrets (rodar 1x): supabase secrets set META_APP_ID=<id> META_APP_SECRET=<secret> --project-ref nxztzehgnkdmluogxehi

# Service Role Key — APENAS para scripts Node.js (seed-superadmin.js etc.)
# NUNCA exponha para o navegador (sem prefixo VITE_).
# Obter em: Supabase Dashboard → Settings → API → service_role (secret key)
SUPABASE_SERVICE_KEY=<service-role-key>
